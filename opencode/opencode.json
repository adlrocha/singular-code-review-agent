{
  "$schema": "https://opencode.ai/config.json",
  "model": "{env:OPENCODE_MODEL}",
  "permission": {
    "edit": "deny",
    "bash": "allow",
    "webfetch": "allow"
  },
  "provider": {
    "opencode-go": {
      "options": {
        "apiKey": "{env:OPENCODE_API_KEY}"
      }
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["context7-mcp"],
      "enabled": true,
      "environment": {
        "CONTEXT7_API_KEY": "{env:CONTEXT7_API_KEY}"
      }
    }
  }
}
